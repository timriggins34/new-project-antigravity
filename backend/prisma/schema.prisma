generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id                String @id @default(uuid())
  client_id         String @unique
  
  // Section 1.1: Identity
  name              String
  nickname          String
  clientType        String // Importer/Exporter/Both
  constitution      String
  status            String // Active/Inactive
  clientSinceYear   String?

  // Section 1.2: Registration
  pan               String
  gstin             String
  iec               String
  cin_llpin         String
  tan               String

  // Section 1.3: Contact
  address           String
  contactPerson     String
  contactNickname   String
  mobile            String
  email             String
  contact1          String
  contact2          String?

  // Section 1.4: Bank
  bankName          String
  branchName        String
  accountNumber     String
  accountType       String
  ifsc              String
  swift             String
  bankAddress       String
  adCode            String

  // Section 1.5: Other
  details           String?

  documents         Document[]
}

model Vendor {
  id            String @id @default(uuid())
  vendor_id     String @unique
  name          String
  type          String
  contact       String
  phone         String
  email         String
  
  clearanceJobs ClearanceJob[]
  freightJobs   FreightJob[]
}

model ClearanceJob {
  id       String @id @default(uuid())
  job_id   String @unique
  client   String
  port     String
  type     String
  stage    String
  status   String
  alert    Boolean
  assigned String
  date     String

  // Duty & Stage Tracking
  icegateChallan String?
  dutyAmount     Float?
  penalty        Float?
  paymentDate    DateTime?
  oocTimestamp   DateTime?

  // Relations
  vendors      Vendor[]
  hsCodeItems  HSCodeItem[]
}

model HSCodeItem {
  id              String       @id @default(uuid())
  itemName        String
  hsCode          String
  assessableValue Float?
  
  clearanceJobId  String
  clearanceJob    ClearanceJob @relation(fields: [clearanceJobId], references: [id])
}

model DocJob {
  id     String @id @default(uuid())
  job_id String @unique
  client String
  status String
  type   String

  // Documentation Checklists
  hasHardCopyBOL Boolean @default(false)
  hasHardCopyDO  Boolean @default(false)

  // Relations
  documents      Document[]
}

model LogisticsTrip {
  id      String @id @default(uuid())
  trip_id String @unique
  job     String
  truck   String
  driver  String
  from    String
  to      String
  status  String
  eta     String
  delayed Boolean @default(false)
}

model Licence {
  id         String @id @default(uuid())
  licence_id String @unique
  client     String
  type       String
  status     String
  expiry     String
  utilized   Int?
  alert      Boolean
}

model FreightJob {
  id     String @id @default(uuid())
  job_id String @unique
  mbl    String?
  awb    String?
  type   String
  pol    String
  pod    String
  vessel String
  etd    String
  eta    String
  status String
  alert  Boolean

  vendors Vendor[]
}

model Document {
  id         String    @id @default(uuid())
  name       String
  url        String?
  uploadedAt DateTime  @default(now())
  
  clientId   String?
  client     Client?   @relation(fields: [clientId], references: [id])
  
  docJobId   String?
  docJob     DocJob?   @relation(fields: [docJobId], references: [id])
}
