generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

model User {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  passwordHash String
  role         Role     @default(EMPLOYEE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Audit Logs performed by this user
  auditLogs    AuditLog[]

  // Relations for created/updated records
  createdClients Client[] @relation("ClientCreator")
  updatedClients Client[] @relation("ClientUpdater")
  
  createdVendors Vendor[] @relation("VendorCreator")
  updatedVendors Vendor[] @relation("VendorUpdater")

  createdClearanceJobs ClearanceJob[] @relation("ClearanceJobCreator")
  updatedClearanceJobs ClearanceJob[] @relation("ClearanceJobUpdater")

  createdHSCodeItems HSCodeItem[] @relation("HSCodeItemCreator")
  updatedHSCodeItems HSCodeItem[] @relation("HSCodeItemUpdater")

  createdDocJobs DocJob[] @relation("DocJobCreator")
  updatedDocJobs DocJob[] @relation("DocJobUpdater")

  createdLogisticsTrips LogisticsTrip[] @relation("LogisticsTripCreator")
  updatedLogisticsTrips LogisticsTrip[] @relation("LogisticsTripUpdater")

  createdLicences Licence[] @relation("LicenceCreator")
  updatedLicences Licence[] @relation("LicenceUpdater")

  createdFreightJobs FreightJob[] @relation("FreightJobCreator")
  updatedFreightJobs FreightJob[] @relation("FreightJobUpdater")

  createdDocuments Document[] @relation("DocumentCreator")
  updatedDocuments Document[] @relation("DocumentUpdater")

  // Assigned Tasks
  assignedClearanceJobs ClearanceJob[] @relation("ClearanceJobAssignee")
  assignedLogisticsTrips LogisticsTrip[] @relation("LogisticsTripAssignee")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String   // e.g., 'CREATE', 'UPDATE', 'DELETE'
  entityName String
  entityId   String
  details    Json
  timestamp  DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id])
}

model Client {
  id                String @id @default(uuid())
  client_id         String @unique
  
  // Section 1.1: Identity
  name              String
  nickname          String
  clientType        String // Importer/Exporter/Both
  constitution      String
  status            String // Active/Inactive
  clientSinceYear   String?

  // Section 1.2: Registration
  pan               String
  gstin             String
  iec               String
  cin_llpin         String
  tan               String

  // Section 1.3: Contact
  address           String
  contactPerson     String
  contactNickname   String
  mobile            String
  email             String
  contact1          String
  contact2          String?

  // Section 1.4: Bank
  bankName          String
  branchName        String
  accountNumber     String
  accountType       String
  ifsc              String
  swift             String
  bankAddress       String
  adCode            String

  // Section 1.5: Other
  details           String?

  documents         Document[]

  // Traceability
  createdById       String?
  createdBy         User?    @relation("ClientCreator", fields: [createdById], references: [id])
  updatedById       String?
  updatedBy         User?    @relation("ClientUpdater", fields: [updatedById], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Vendor {
  id            String @id @default(uuid())
  vendor_id     String @unique
  name          String
  type          String
  contact       String
  phone         String
  email         String
  
  clearanceJobs ClearanceJob[]
  freightJobs   FreightJob[]
  documents     Document[]

  // Traceability
  createdById       String?
  createdBy         User?    @relation("VendorCreator", fields: [createdById], references: [id])
  updatedById       String?
  updatedBy         User?    @relation("VendorUpdater", fields: [updatedById], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ClearanceJob {
  id       String @id @default(uuid())
  job_id   String @unique
  client   String
  port     String
  type     String
  stage    String
  status   String
  alert    Boolean
  date     String

  assignedToId      String?
  assignedTo        User?    @relation("ClearanceJobAssignee", fields: [assignedToId], references: [id])

  // Duty & Stage Tracking
  icegateChallan String?
  dutyAmount     Float?
  penalty        Float?
  paymentDate    DateTime?
  oocTimestamp   DateTime?

  // Relations
  vendors      Vendor[]
  hsCodeItems  HSCodeItem[]
  documents    Document[]

  // Traceability
  createdById       String?
  createdBy         User?    @relation("ClearanceJobCreator", fields: [createdById], references: [id])
  updatedById       String?
  updatedBy         User?    @relation("ClearanceJobUpdater", fields: [updatedById], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model HSCodeItem {
  id              String       @id @default(uuid())
  itemName        String
  hsCode          String
  assessableValue Float?
  
  clearanceJobId  String
  clearanceJob    ClearanceJob @relation(fields: [clearanceJobId], references: [id])

  // Traceability
  createdById       String?
  createdBy         User?    @relation("HSCodeItemCreator", fields: [createdById], references: [id])
  updatedById       String?
  updatedBy         User?    @relation("HSCodeItemUpdater", fields: [updatedById], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model DocJob {
  id     String @id @default(uuid())
  job_id String @unique
  client String
  status String
  type   String

  // Documentation Checklists
  hasHardCopyBOL Boolean @default(false)
  hasHardCopyDO  Boolean @default(false)

  // Relations
  documents      Document[]

  // Traceability
  createdById       String?
  createdBy         User?    @relation("DocJobCreator", fields: [createdById], references: [id])
  updatedById       String?
  updatedBy         User?    @relation("DocJobUpdater", fields: [updatedById], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model LogisticsTrip {
  id      String @id @default(uuid())
  trip_id String @unique
  job     String
  truck   String
  driver  String
  from    String
  to      String
  status  String
  eta     String
  delayed Boolean @default(false)

  assignedToId      String?
  assignedTo        User?    @relation("LogisticsTripAssignee", fields: [assignedToId], references: [id])
  
  documents         Document[]

  // Traceability
  createdById       String?
  createdBy         User?    @relation("LogisticsTripCreator", fields: [createdById], references: [id])
  updatedById       String?
  updatedBy         User?    @relation("LogisticsTripUpdater", fields: [updatedById], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Licence {
  id         String @id @default(uuid())
  licence_id String @unique
  client     String
  type       String
  status     String
  expiry     String
  utilized   Int?
  alert      Boolean

  // Traceability
  createdById       String?
  createdBy         User?    @relation("LicenceCreator", fields: [createdById], references: [id])
  updatedById       String?
  updatedBy         User?    @relation("LicenceUpdater", fields: [updatedById], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model FreightJob {
  id     String @id @default(uuid())
  job_id String @unique
  mbl    String?
  awb    String?
  type   String
  pol    String
  pod    String
  vessel String
  etd    String
  eta    String
  status String
  alert  Boolean

  vendors Vendor[]

  // Traceability
  createdById       String?
  createdBy         User?    @relation("FreightJobCreator", fields: [createdById], references: [id])
  updatedById       String?
  updatedBy         User?    @relation("FreightJobUpdater", fields: [updatedById], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Document {
  id         String    @id @default(uuid())
  name       String
  url        String?
  uploadedAt DateTime  @default(now())
  
  clientId   String?
  client     Client?   @relation(fields: [clientId], references: [id])
  
  docJobId   String?
  docJob     DocJob?   @relation(fields: [docJobId], references: [id])

  vendorId   String?
  vendor     Vendor?   @relation(fields: [vendorId], references: [id])

  clearanceJobId String?
  clearanceJob   ClearanceJob? @relation(fields: [clearanceJobId], references: [id])

  logisticsTripId String?
  logisticsTrip   LogisticsTrip? @relation(fields: [logisticsTripId], references: [id])

  // Traceability
  createdById       String?
  createdBy         User?    @relation("DocumentCreator", fields: [createdById], references: [id])
  updatedById       String?
  updatedBy         User?    @relation("DocumentUpdater", fields: [updatedById], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
